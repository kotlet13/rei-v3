  "input_exposure_policy": {
    "policy_id": "c2-input-exposure-v1",
    "required_scopes": [
      "actual_artifact_ids",
      "visible_observation_ids",
      "grounded_evidence_ids",
      "allowed_option_ids",
      "forbidden_native_truth_ids",
      "forbidden_profile_ids"
    ],
    "profile_leakage": "actual input intersects forbidden_profile_ids",
    "hidden_ground_truth_leakage": "actual input or candidate claim support intersects forbidden_native_truth_ids",
    "text_canary_is_supporting_evidence_only": true,
    "candidate_self_report_is_sufficient": false
  },
  "claim_support_policy": {
    "policy_id": "c2-structured-claim-support-v1",
    "candidate_claim_fields": [
      "claim_id",
      "facet",
      "value_id",
      "source_claim_ids",
      "evidence_ids",
      "observation_ids",
      "provenance_kind"
    ],
    "supported_claim": "every cited evidence or observation ID is visible and allowed for the candidate",
    "unsupported_claim_count": "number of candidate claims with no allowed supporting ID or with forbidden support",
    "source_evidence_coverage": "covered expected evidence IDs divided by expected evidence IDs",
    "free_text_keyword_match_is_not_claim_support": true
  },
  "calibration_policy": {
    "policy_id": "c2-per-case-brier-calibration-v1",
    "unit": "one manually reviewed evaluation case",
    "correctness_target": "1 when all non-calibration semantic expectations for the candidate pass, otherwise 0",
    "formula": "(candidate_confidence - correctness_target) ** 2",
    "pass_condition": "brier_error <= max_brier_error",
    "default_max_brier_error": 0.25,
    "abstention_is_scored_against_expected_abstention": true,
    "aggregate_empirical_calibration_claim_allowed": false
  },
  "distortion_policy": {
    "policy_id": "c2-explicit-distortion-evidence-v1",
    "labels": {
      "accurate": "expected option and motive facets are supported by visible evidence with no forbidden native-truth support",
      "partial": "at least one expected supported facet is preserved and at least one is explicitly omitted",
      "omission": "no substantive interpretation is emitted or justification_kind is omitted",
      "rationalization": "an explicit self-justification claim replaces a contradicted or unsupported visible-source explanation",
      "minimization": "a visible signal is explicitly downscaled despite trusted visible evidence for the stronger signal",
      "projection": "a self-state or self-motive is attributed to the source mind without trusted visible support",
      "misclassification": "a structured option, action tendency, or motive class conflicts with the trusted expected value",
      "unknown": "the explicit evaluator evidence does not satisfy exactly one more specific label"
    },
    "required_evidence_fields": [
      "evidence_kind",
      "visible_support_ids",
      "candidate_claim_ids",
      "contradicted_claim_ids",
      "expected_label"
    ],
    "keyword_classifier_allowed": false,
    "native_truth_may_be_sent_back_to_interpreter": false
  },
  "ego_motif_policy": {
    "policy_id": "c2-recurring-motif-two-measure-v1",
    "minimum_distinct_supporting_measure_ids": 2,
    "scope": "evaluated recurring motifs only",
    "does_not_change_single_measure_runtime_fields": true,
    "true_positive": "candidate motif ID is expected and has support from at least two distinct in-scope measures",
    "false_positive": "candidate motif ID is not expected or lacks the minimum support",
    "false_negative": "expected motif ID is absent from valid candidate motifs",
    "false_motif_rate": "false_positive_count / candidate_motif_count; not_applicable when candidate_motif_count is zero",
    "missed_motif_rate": "false_negative_count / expected_motif_count; not_applicable when expected_motif_count is zero"
  },
  "bilingual_policy": {
    "policy_id": "c2-bilingual-structured-signature-v1",
    "signature_fields": [
      "mind",
      "option_id",
      "abstains",
      "route_tags",
      "evidence_ids",
      "interpretation_class"
    ],
    "comparison": "exact equality after canonical ordering of set-valued fields",
    "slovenian_text_is_authoritative": true,
    "english_text_is_operational_gloss": true,
    "text_embedding_required": false,
    "model_judge_required": false,
    "natural_language_translation_quality_requires_human_review": true
  },
  "terminology_policy": {
    "policy_id": "c2-slovenian-terminology-v1",
    "source": "knowledge/canon_v2/glossary.yaml",
    "required_canonical_terms": {
